# ====================================================
# TRENDPULSE NEWS INTELLIGENCE - ENVIRONMENT EXAMPLES
# ====================================================

# Node Runtime Configuration
NODE_ENV=production
PORT=3000

# Server / Public App URL (For links, self-reference, and SSE connections)
# e.g., https://trendpulse-backend.onrender.com or http://localhost:3000
APP_URL=http://localhost:3000

# Google Gemini Pro Model Credentials
# Server-side API key for intelligent semantic consolidation, keyword extraction, and summaries.
GEMINI_API_KEY=your_google_gemini_api_key_here

# ----------------------------------------------------
# DATABASE CONFIGURATIONS (Supabase / Relational PostgreSQL)
# ----------------------------------------------------

# Direct PostgreSQL Connection String (Transaction pooler or direct session port)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://postgres:your-db-password@db.supabase.co:5432/postgres

# Supabase Client API Configs (If using Supabase Client SDK in the code)
SUPABASE_URL=https://your-supabase-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anonymous-anon-key-here
